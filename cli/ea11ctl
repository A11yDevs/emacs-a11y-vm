            ;;
        list)
            invoke_share_folder_list "$@"
            ;;
        *)
            ea11_error "Ação desconhecida de share-folder: $action"
            return 1
            ;;
    esac
}

invoke_vm_command() {
    local action="${1:-}"
    shift || true
    
    case "$action" in
        install|-i)
            invoke_vm_install "$@"
            ;;
        list|-l)
            invoke_vm_list "$@"
            ;;
        start|-s)
            invoke_vm_start "$@"
            ;;
        stop|-S)
            invoke_vm_stop "$@"
            ;;
        close|-c)
            invoke_vm_close "$@"
            ;;
        status|-q)
            invoke_vm_status "$@"
            ;;
        diagnose|-d)
            invoke_vm_diagnose "$@"
            ;;
        ssh|-x)
            invoke_vm_ssh "$@"
            ;;
        share-folder|-F)
            invoke_vm_share_folder "$@"
            ;;
        *)
            ea11_error "Subcomando vm desconhecido: $action"
            show_help
            return 1
            ;;
    esac
}

