EOF
}

#################################################################################
# Main
#################################################################################

main() {
    local command="${1:-}"
    shift || true
    
    case "$command" in
        help|-h|--help)
            show_help
            ;;
        version|--version)
            invoke_version_command "$@"
            ;;
        self-update|update)
            invoke_self_update "$@"
            ;;
        vm)
            invoke_vm_command "$@"
            ;;
        "")
            show_help
            exit 0
            ;;
        *)
            ea11_error "Comando desconhecido: $command"
            show_help
            exit 1
            ;;
    esac
}

# Executar main com tratamento de erro
if ! main "$@"; then
    show_help
    exit 1
fi
