#!/bin/bash

#################################################################################
# ea11ctl - CLI do projeto emacs-a11y-vm para bash (macOS, Linux)
# Version: compatível com a CLI de PowerShell
#################################################################################

set -euo pipefail

# Constantes
EA11CTL_FALLBACK_VERSION='0.1.32'
EA11CTL_OWNER='A11yDevs'
EA11CTL_REPO='emacs-a11y-vm'
EA11CTL_BRANCH='main'
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

#################################################################################
# Funções de Logging
#################################################################################

ea11_info() {
    printf '\033[36m[ea11ctl] %s\033[0m\n' "$*" >&2
}

ea11_warn() {
    printf '\033[33m[ea11ctl] %s\033[0m\n' "$*" >&2
}

ea11_error() {
    printf '\033[31m[ea11ctl] %s\033[0m\n' "$*" >&2
}

ea11_success() {
    printf '\033[32m%s\033[0m\n' "$*" >&2
}

#################################################################################
# Funções de Versão
#################################################################################

get_local_cli_version() {
    local version_file="$SCRIPT_DIR/VERSION"
    if [[ -f "$version_file" ]]; then
        local version
        version=$(tr -d '[:space:]' < "$version_file")
        if [[ -n "$version" ]]; then
            echo "$version"
            return 0
        fi
    fi
    echo "$EA11CTL_FALLBACK_VERSION"
}

get_remote_cli_version() {
    local url="https://raw.githubusercontent.com/$EA11CTL_OWNER/$EA11CTL_REPO/$EA11CTL_BRANCH/cli/VERSION"
    local result
    result=$(curl -s --max-time 5 "$url" 2>/dev/null || echo '')
    if [[ -n "$result" ]]; then
        echo "$result" | tr -d '[:space:]'
    else
        echo ""
    fi
}

get_github_api_version() {
    local url="https://api.github.com/repos/$EA11CTL_OWNER/$EA11CTL_REPO/commits/$EA11CTL_BRANCH"
    local result
    result=$(curl -s --max-time 5 \
        -H 'Accept: application/vnd.github+json' \
        "$url" 2>/dev/null || echo '')
    
    if [[ -n "$result" ]]; then
        echo "$result" | grep -o '"sha":"[^"]*' | head -1 | cut -d'"' -f4
    else
        echo ""
    fi
}

invoke_version_command() {
    local local_version
    local_version=$(get_local_cli_version)
    echo "ea11ctl v$local_version"
    
    if ! has_flag "$@" --check-update -c; then
        return 0
    fi
    
    local remote_version
    remote_version=$(get_remote_cli_version) || true
    
    if [[ -z "$remote_version" ]]; then
        ea11_warn "Não foi possível consultar versão remota"
        return 0
    fi
    
    if [[ "$remote_version" == "$local_version" ]]; then
        ea11_info "Você já está na versão mais recente ($local_version)."
    else
        ea11_info "Nova versão disponível: $remote_version (local: $local_version)"
        echo "Use: ea11ctl self-update" | sed 's/^/  /'
    fi
}

#################################################################################
# Funções de Atualização
#################################################################################

invoke_self_update() {
    local force=0
    if has_flag "$@" --force -f; then
        force=1
    fi
    
    local local_version
    local_version=$(get_local_cli_version)
    
    if [[ $force -eq 0 ]]; then
        local remote_version
        remote_version=$(get_remote_cli_version) || true
        
        if [[ -z "$remote_version" ]]; then
            ea11_warn "Não foi possível validar versão remota; prosseguindo com update."
        elif [[ "$remote_version" == "$local_version" ]]; then
            ea11_info "ea11ctl já está atualizado (v$local_version)."
            return 0
        else
            ea11_info "Atualizando ea11ctl de v$local_version para v$remote_version..."
        fi
    fi
    
    # Resolvendo a referência remota (commit SHA)
    local resolved_ref="$EA11CTL_BRANCH"
    local commit_sha
    commit_sha=$(get_github_api_version) || true
    
    if [[ -n "$commit_sha" ]]; then
        resolved_ref="$commit_sha"
        ea11_info "Ref remoto resolvido para commit $resolved_ref"
    else
        ea11_warn "Não foi possível resolver SHA da branch; usando ref '$EA11CTL_BRANCH'."
    fi
    
    local install_dir="$SCRIPT_DIR"
    local tmp_dir
    tmp_dir=$(mktemp -d -t ea11ctl-update-XXXXXX)
    trap "rm -rf '$tmp_dir'" EXIT
    
    local files=(ea11ctl ea11ctl.ps1 ea11ctl.cmd install.sh VERSION)
    local cache_bust
    cache_bust=$(date +%s)
    
    local download_ok=0
    local last_error=""
    
    for ref in "$resolved_ref" "$EA11CTL_BRANCH"; do
        ea11_info "Tentando download dos arquivos via ref '$ref'..."
        download_ok=1
        
        for file in "${files[@]}"; do
            local dest="$tmp_dir/$file"
            local url="https://raw.githubusercontent.com/$EA11CTL_OWNER/$EA11CTL_REPO/$ref/cli/$file?cb=$cache_bust"
            
            if ! curl -fsSL "$url" -o "$dest" 2>/dev/null; then
                last_error="Falha ao baixar $file"
                download_ok=0
                break
            fi
        done
        
        if [[ $download_ok -eq 1 ]]; then
            break
        fi
    done
    
    if [[ $download_ok -eq 0 ]]; then
        ea11_error "Não foi possível baixar arquivos de update. Último erro: $last_error"
        return 1
    fi
    
    # Copiar os arquivos baixados
    for file in "${files[@]}"; do
        local src="$tmp_dir/$file"
        local dest="$install_dir/$file"
        if [[ -f "$src" ]]; then
            cp "$src" "$dest"
            [[ "$file" == "ea11ctl" ]] && chmod +x "$dest"
        fi
    done

    sync_backend_scripts_from_remote || true
    
    local new_version
    new_version=$(get_local_cli_version)
    ea11_success "ea11ctl atualizado para v$new_version"
}

#################################################################################
# Funções Utilitárias
#################################################################################

has_flag() {
    local flag
    for arg in "$@"; do
        for flag in "$@"; do
            if [[ "$arg" == "$flag" ]]; then
                return 0
            fi
        done
    done
    return 1
}

has_flag() {
    local searching=1
    for arg in "$@"; do
        if [[ $searching -eq 1 ]]; then
            if [[ "$arg" == "--"* ]] || [[ "$arg" == "-"* ]]; then
                searching=0
            fi
            continue
        fi
        
        for flag in "$@"; do
            [[ "$flag" == "$arg" ]] && return 0
        done
    done
    
    for flag in "$@"; do
        for arg in "$@"; do
            [[ "$arg" == "$flag" ]] && return 0
        done
    done
    
    return 1
}

# Versão corrigida
has_flag() {
    local needle="$1"
    shift
    for arg in "$@"; do
        [[ "$arg" == "$needle" ]] && return 0
    done
    return 1
}

get_option_value() {
    local name="$1"
    shift
    local i=0
    for arg in "$@"; do
        if [[ "$arg" == "$name" ]] && (( i + 1 < $# )); then
            echo "${@:i+2:1}"
            return 0
        fi
        ((i++))
    done
    return 1
}

get_home_directory() {
    if [[ -n "${HOME:-}" ]]; then
        echo "$HOME"
    else
        echo ~
    fi
}

get_ea11_state_directory() {
    local base
    base=$(get_home_directory)/.emacs-a11y-vm
    mkdir -p "$base"
    echo "$base"
}

get_ea11_scripts_directory() {
    local scripts_dir
    scripts_dir="$(get_ea11_state_directory)/scripts"
    mkdir -p "$scripts_dir"
    echo "$scripts_dir"
}

vm_backend_flag_present() {
    local arg
    for arg in "$@"; do
        case "$arg" in
            -b|--backend|--qemu|--virtualbox)
                return 0
                ;;
        esac
    done
    return 1
}

qemu_has_registered_vm() {
    local qemu_state_dir
    qemu_state_dir="$(get_ea11_state_directory)/qemu"

    if [[ ! -d "$qemu_state_dir" ]]; then
        return 1
    fi

    shopt -s nullglob
    local files=("$qemu_state_dir"/*.env)
    shopt -u nullglob

    [[ ${#files[@]} -gt 0 ]]
}

sync_backend_scripts_from_repo() {
    local source_dir="$SCRIPT_DIR/backend-scripts"
    local target_dir
    target_dir=$(get_ea11_scripts_directory)
    local file

    if [[ ! -d "$source_dir" ]]; then
        return 0
    fi

    for file in common.sh qemu.sh virtualbox.sh; do
        if [[ -f "$source_dir/$file" ]]; then
            cp "$source_dir/$file" "$target_dir/$file"
        fi
    done

    chmod +x "$target_dir/qemu.sh" "$target_dir/virtualbox.sh" 2>/dev/null || true
}

sync_backend_scripts_from_remote() {
    local target_dir
    target_dir=$(get_ea11_scripts_directory)
    local base_url="https://raw.githubusercontent.com/$EA11CTL_OWNER/$EA11CTL_REPO/$EA11CTL_BRANCH/cli/backend-scripts"
    local file

    for file in common.sh qemu.sh virtualbox.sh; do
        if ! curl -fsSL "$base_url/$file" -o "$target_dir/$file" 2>/dev/null; then
            ea11_warn "Nao foi possivel atualizar backend script: $file"
            return 1
        fi
    done

    chmod +x "$target_dir/qemu.sh" "$target_dir/virtualbox.sh" 2>/dev/null || true
}

resolve_vm_backend() {
    local backend='virtualbox'
    local current
    while [[ $# -gt 0 ]]; do
        current="$1"
        shift
        case "$current" in
            -b|--backend)
                if [[ $# -eq 0 ]]; then
                    ea11_error 'Use --backend com um valor (virtualbox ou qemu).'
                    return 1
                fi
                backend="$1"
                shift
                ;;
            --qemu)
                backend='qemu'
                ;;
            --virtualbox)
                backend='virtualbox'
                ;;
        esac
    done

    case "$backend" in
        virtualbox|qemu)
            echo "$backend"
            ;;
        *)
            ea11_error "Backend desconhecido: $backend"
            return 1
            ;;
    esac
}

resolve_backend_script_path() {
    local backend="$1"
    local target_dir
    target_dir=$(get_ea11_scripts_directory)

    if [[ -f "$target_dir/$backend.sh" ]]; then
        echo "$target_dir/$backend.sh"
        return 0
    fi

    sync_backend_scripts_from_repo
    if [[ -f "$target_dir/$backend.sh" ]]; then
        echo "$target_dir/$backend.sh"
        return 0
    fi

    ea11_error "Script de backend nao encontrado para '$backend' em $target_dir. Reinstale a CLI ou execute o instalador novamente."
    return 1
}

run_backend_command() {
    local backend="$1"
    local command="$2"
    shift 2

    local script_path
    script_path=$(resolve_backend_script_path "$backend") || return 1
    bash "$script_path" "$command" "$@"
}

#################################################################################
# Funcoes de VM
#################################################################################

invoke_vm_install() {
    local backend
    backend=$(resolve_vm_backend "$@") || return 1
    run_backend_command "$backend" install "$@"
}

invoke_vm_list() {
    local backend
    backend=$(resolve_vm_backend "$@") || return 1
    run_backend_command "$backend" list "$@"
}

invoke_vm_start() {
    local backend
    backend=$(resolve_vm_backend "$@") || return 1
    run_backend_command "$backend" start "$@"
}

invoke_vm_stop() {
    local backend
    backend=$(resolve_vm_backend "$@") || return 1
    run_backend_command "$backend" stop "$@"
}

invoke_vm_status() {
    local backend
    backend=$(resolve_vm_backend "$@") || return 1
    run_backend_command "$backend" status "$@"
}

invoke_vm_ssh() {
    local backend
    backend=$(resolve_vm_backend "$@") || return 1
    run_backend_command "$backend" ssh "$@"
}

invoke_vm_diagnose() {
    local backend
    backend=$(resolve_vm_backend "$@") || return 1
    run_backend_command "$backend" diagnose "$@"
}

invoke_vm_close() {
    local backend
    backend=$(resolve_vm_backend "$@") || return 1
    run_backend_command "$backend" close "$@"
}

invoke_share_folder_add() {
    run_backend_command virtualbox share-folder add "$@"
}

invoke_share_folder_remove() {
    run_backend_command virtualbox share-folder remove "$@"
}

invoke_share_folder_list() {
    run_backend_command virtualbox share-folder list "$@"
}

invoke_vm_share_folder() {
    local action="${1:-list}"
    shift || true
    
    case "$action" in
        add)
            invoke_share_folder_add "$@"
            ;;
        remove)
            invoke_share_folder_remove "$@"
            ;;
        list)
            invoke_share_folder_list "$@"
            ;;
        *)
            ea11_error "Ação desconhecida de share-folder: $action"
            return 1
            ;;
    esac
}

invoke_vm_command() {
    local action="${1:-}"
    shift || true
    
    case "$action" in
        install|-i)
            invoke_vm_install "$@"
            ;;
        version|-V)
            local backend
            if ! vm_backend_flag_present "$@" && qemu_has_registered_vm; then
                backend='qemu'
            else
                backend=$(resolve_vm_backend "$@") || return 1
            fi
            run_backend_command "$backend" version "$@"
            ;;
        check-update|-U)
            local backend
            if ! vm_backend_flag_present "$@" && qemu_has_registered_vm; then
                backend='qemu'
            else
                backend=$(resolve_vm_backend "$@") || return 1
            fi
            run_backend_command "$backend" check-update "$@"
            ;;
        list|-l)
            invoke_vm_list "$@"
            ;;
        start|-s)
            invoke_vm_start "$@"
            ;;
        stop|-S)
            invoke_vm_stop "$@"
            ;;
        close|-c)
            invoke_vm_close "$@"
            ;;
        status|-q)
            invoke_vm_status "$@"
            ;;
        diagnose|-d)
            invoke_vm_diagnose "$@"
            ;;
        ssh|-x)
            invoke_vm_ssh "$@"
            ;;
        share-folder|-F)
            invoke_vm_share_folder "$@"
            ;;
        *)
            ea11_error "Subcomando vm desconhecido: $action"
            show_help
            return 1
            ;;
    esac
}

#################################################################################
# Help
#################################################################################

show_help() {
    cat << 'EOF'
ea11ctl - CLI do projeto emacs-a11y-vm

Uso:
  ea11ctl help|-h|--help
  ea11ctl version|--version [-c|--check-update]
  ea11ctl self-update|update [-f|--force]
    ea11ctl vm install|-i [args-do-install-release-vm.sh]
    ea11ctl vm version|-V [-n|--name VM] [--backend virtualbox|qemu]
    ea11ctl vm check-update|-U [-n|--name VM] [--backend virtualbox|qemu]
  ea11ctl vm list|-l [--backend virtualbox|qemu]
  ea11ctl vm start|-s [-n|--name VM] [-h|--headless] [--backend virtualbox|qemu]
  ea11ctl vm stop|-S [-n|--name VM] [-f|--force] [--backend virtualbox|qemu]
  ea11ctl vm close|-c [-n|--name VM] [-t|--timeout SEGUNDOS] [--backend virtualbox|qemu]
  ea11ctl vm diagnose|-d [-n|--name VM] [-T|--try-start] [-L|--lines N] [--backend virtualbox|qemu]
  ea11ctl vm status|-q [-n|--name VM] [--backend virtualbox|qemu]
  ea11ctl vm ssh|-x [-u|--user USER] [-p|--port PORT] [--backend virtualbox|qemu] [-- extra-args]
  ea11ctl vm share-folder|-F add [-n|--name VM] -p|--path CAMINHO [--name NOME] [-r|--readonly]
  ea11ctl vm share-folder|-F remove [-n|--name VM] --name NOME
  ea11ctl vm share-folder|-F list [-n|--name VM]

Defaults:
    Backend: virtualbox
  VM: debian-a11y
  SSH user: a11ydevs
  SSH port: 2222

QEMU:
    Imagem de sistema: ~/.emacs-a11y-vm/debian-a11ydevs.qcow2
    Disco de dados: ~/.emacs-a11y-vm/<vm>-home.qcow2 (montado em /home na VM)
EOF
}

#################################################################################
# Main
#################################################################################

main() {
    local command="${1:-}"
    shift || true
    
    case "$command" in
        help|-h|--help)
            show_help
            ;;
        version|--version)
            invoke_version_command "$@"
            ;;
        self-update|update)
            invoke_self_update "$@"
            ;;
        vm)
            invoke_vm_command "$@"
            ;;
        "")
            show_help
            exit 0
            ;;
        *)
            ea11_error "Comando desconhecido: $command"
            show_help
            exit 1
            ;;
    esac
}

# Executar main com tratamento de erro
if ! main "$@"; then
    exit 1
fi
